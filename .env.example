APP_NAME=Drivee NL2SQL Backend
APP_ENV=local
DEBUG=true
API_PREFIX=/api
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

POSTGRES_DB=drivee
POSTGRES_USER=drivee
POSTGRES_PASSWORD=drivee
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://drivee:drivee@postgres:5432/drivee

REDIS_URL=redis://redis:6379/0

JWT_SECRET_KEY=change-me-super-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123

OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_MODEL=qwen3:4b
# NL2SQL + model inference can exceed 2 minutes on large prompts / cold GPU.
OLLAMA_TIMEOUT_SECONDS=300

# Put files into ./data with these names.
INCITY_CSV_PATH=/data/incity.csv
PASS_DETAIL_CSV_PATH=/data/pass_detail.csv
DRIVER_DETAIL_CSV_PATH=/data/driver_detail.csv
DATASET_NOTES_PATH=/data/notes.md
GOOD_PROMPTS_PATH=/data/goodprompts.txt
SEMANTIC_LAYER_PATH=/app/src/semantic/semantic_layer.json
IMPORT_DATASETS_ON_STARTUP=true

SQL_DEFAULT_LIMIT=100
SQL_MAX_LIMIT=500
# PostgreSQL statement_timeout for executed analytics SQL (heavy GROUP BY / COUNT DISTINCT on large tables).
SQL_STATEMENT_TIMEOUT_MS=180000
SQL_MAX_OFFSET=1000
SQL_MAX_TABLE_REFERENCES=3
SQL_MAX_EXPLAIN_TOTAL_COST=2000000
SQL_MAX_EXPLAIN_PLAN_ROWS=2000000
SQL_BLOCK_SELECT_STAR=true
SQL_BLOCK_CROSS_JOIN=true
SQL_READONLY_TRANSACTION=true

TEMPLATES_CACHE_TTL_SECONDS=86400
TEMPLATE_RESULT_CACHE_TTL_SECONDS=600
TEMPLATE_MATCH_THRESHOLD=0.88

REPORT_SCHEDULER_ENABLED=true
REPORT_SCHEDULER_INTERVAL_SECONDS=300
REPORT_SCHEDULER_BATCH_SIZE=10
DEFAULT_REPORT_SCHEDULE_TIMEZONE=UTC
