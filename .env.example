# ===== App =====
APP_NAME=Drivee NL2SQL Backend
APP_ENV=local
DEBUG=true
API_PREFIX=/api

# Для локального фронта потом можно оставить localhost:3000
BACKEND_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

# ===== Postgres =====
POSTGRES_DB=drivee
POSTGRES_USER=drivee
POSTGRES_PASSWORD=drivee
POSTGRES_PORT=5432
DATABASE_URL=postgresql+psycopg2://drivee:drivee@db:5432/drivee

# ===== Auth =====
JWT_SECRET_KEY=change-me-super-secret-key-at-least-32-chars
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Демо-пользователь создается при старте
FIRST_SUPERUSER_EMAIL=admin@example.com
FIRST_SUPERUSER_PASSWORD=admin123

# ===== Ollama =====
# Если backend запущен в Docker, используй host.docker.internal.
# Если backend запущен напрямую на ПК без Docker, поменяй на http://localhost:11434
OLLAMA_BASE_URL=http://host.docker.internal:11434
OLLAMA_MODEL=qwen3:4b
OLLAMA_TIMEOUT_SECONDS=120

# ===== Dataset =====
TRAIN_CSV_PATH=/data/train.csv
TRAIN_NOTES_PATH=/data/notes.md
IMPORT_TRAIN_ON_STARTUP=true

# ===== SQL guardrails =====
SQL_DEFAULT_LIMIT=100
SQL_MAX_LIMIT=500
SQL_STATEMENT_TIMEOUT_MS=15000
