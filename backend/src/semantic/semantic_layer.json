{
  "version": "1.0",
  "table": "train",
  "grain": {
    "ru": "Одна строка = одна комбинация order_id и tender_id. Для бизнес-подсчёта заказов используй COUNT(DISTINCT order_id), а не COUNT(*), если пользователь явно не просит строки/тендеры.",
    "sql_rule": "business_order_count = COUNT(DISTINCT order_id)"
  },
  "columns": {
    "city_id": {
      "type": "INTEGER",
      "description_ru": "идентификатор города",
      "business_terms": [
        "город",
        "города",
        "по городам",
        "локация"
      ]
    },
    "order_id": {
      "type": "TEXT",
      "description_ru": "анонимизированный идентификатор заказа; использовать вместо id",
      "business_terms": [
        "заказ",
        "заказы",
        "поездка",
        "поездки",
        "order",
        "id заказа"
      ]
    },
    "tender_id": {
      "type": "TEXT",
      "description_ru": "анонимизированный идентификатор тендера/подбора водителя",
      "business_terms": [
        "тендер",
        "тендеры",
        "подбор водителя",
        "предложение водителю"
      ]
    },
    "user_id": {
      "type": "TEXT",
      "description_ru": "анонимизированный идентификатор пользователя/клиента",
      "business_terms": [
        "пользователь",
        "клиент",
        "пассажир"
      ]
    },
    "driver_id": {
      "type": "TEXT",
      "description_ru": "анонимизированный идентификатор водителя; NULL означает, что водитель не назначен и такую строку нельзя считать водителем в рейтингах водителей",
      "business_terms": [
        "водитель",
        "водители",
        "драйвер",
        "топ водителей",
        "лучшие водители",
        "водители по заказам",
        "рейтинг водителей"
      ]
    },
    "offset_hours": {
      "type": "INTEGER",
      "description_ru": "смещение локального времени города относительно UTC в часах",
      "business_terms": [
        "часовой пояс",
        "смещение"
      ]
    },
    "status_order": {
      "type": "TEXT",
      "description_ru": "итоговый статус заказа",
      "values": {
        "done": "заказ завершён/поездка выполнена",
        "cancel": "заказ отменён",
        "delete": "заказ удалён"
      },
      "business_terms": [
        "статус заказа",
        "завершённые",
        "отменённые",
        "удалённые"
      ]
    },
    "status_tender": {
      "type": "TEXT",
      "description_ru": "статус тендера или процесса подбора водителя",
      "values": {
        "decline": "водитель/тендер отклонён"
      },
      "business_terms": [
        "статус тендера",
        "отклонения",
        "отказы",
        "decline"
      ]
    },
    "order_timestamp": {
      "type": "TIMESTAMP",
      "description_ru": "время создания заказа; основное поле для фильтрации по датам",
      "business_terms": [
        "дата",
        "день",
        "неделя",
        "месяц",
        "год",
        "период",
        "вчера",
        "сегодня"
      ]
    },
    "tender_timestamp": {
      "type": "TIMESTAMP",
      "description_ru": "время создания или начала тендера",
      "business_terms": [
        "время тендера",
        "начало тендера"
      ]
    },
    "driveraccept_timestamp": {
      "type": "TIMESTAMP",
      "description_ru": "время принятия заказа водителем",
      "business_terms": [
        "принятие водителем",
        "принял заказ",
        "до принятия"
      ]
    },
    "driverarrived_timestamp": {
      "type": "TIMESTAMP",
      "description_ru": "время прибытия водителя",
      "business_terms": [
        "прибытие водителя",
        "водитель приехал"
      ]
    },
    "driverstarttheride_timestamp": {
      "type": "TIMESTAMP",
      "description_ru": "время начала поездки",
      "business_terms": [
        "начало поездки",
        "старт поездки"
      ]
    },
    "driverdone_timestamp": {
      "type": "TIMESTAMP",
      "description_ru": "время завершения поездки",
      "business_terms": [
        "конец поездки",
        "завершение поездки"
      ]
    },
    "clientcancel_timestamp": {
      "type": "TIMESTAMP",
      "description_ru": "время отмены заказа клиентом",
      "business_terms": [
        "отмена клиентом",
        "клиент отменил"
      ]
    },
    "drivercancel_timestamp": {
      "type": "TIMESTAMP",
      "description_ru": "время отмены заказа водителем",
      "business_terms": [
        "отмена водителем",
        "водитель отменил"
      ]
    },
    "order_modified_local": {
      "type": "TIMESTAMP",
      "description_ru": "время последнего изменения заказа",
      "business_terms": [
        "изменение заказа",
        "обновление заказа"
      ]
    },
    "cancel_before_accept_local": {
      "type": "TIMESTAMP",
      "description_ru": "время отмены до принятия заказа водителем",
      "business_terms": [
        "отмена до принятия",
        "отменили до водителя"
      ]
    },
    "distance_in_meters": {
      "type": "INTEGER",
      "description_ru": "расстояние поездки в метрах",
      "business_terms": [
        "расстояние",
        "дистанция",
        "километры",
        "метры"
      ]
    },
    "duration_in_seconds": {
      "type": "INTEGER",
      "description_ru": "длительность поездки или заказа в секундах",
      "business_terms": [
        "длительность",
        "время поездки",
        "продолжительность"
      ]
    },
    "price_order_local": {
      "type": "NUMERIC(14, 2)",
      "description_ru": "итоговая стоимость заказа в локальной валюте; основное поле для цены/выручки/чека",
      "business_terms": [
        "цена",
        "стоимость",
        "итоговая цена",
        "выручка",
        "оборот",
        "чек",
        "самые дорогие"
      ]
    },
    "price_tender_local": {
      "type": "NUMERIC(14, 2)",
      "description_ru": "стоимость на этапе тендера в локальной валюте",
      "business_terms": [
        "цена тендера",
        "стоимость тендера"
      ]
    },
    "price_start_local": {
      "type": "NUMERIC(14, 2)",
      "description_ru": "стартовая стоимость заказа в локальной валюте",
      "business_terms": [
        "стартовая цена",
        "начальная цена"
      ]
    }
  },
  "metrics": {
    "total_orders": {
      "title_ru": "Всего заказов",
      "sql": "COUNT(DISTINCT order_id)",
      "terms": [
        "сколько заказов",
        "всего заказов",
        "количество заказов"
      ]
    },
    "done_orders": {
      "title_ru": "Завершённые заказы",
      "sql": "COUNT(DISTINCT order_id) FILTER (WHERE status_order = 'done')",
      "terms": [
        "завершенные",
        "выполненные",
        "поездки выполнены",
        "done"
      ]
    },
    "canceled_orders": {
      "title_ru": "Отменённые заказы",
      "sql": "COUNT(DISTINCT order_id) FILTER (WHERE status_order = 'cancel')",
      "terms": [
        "отмены",
        "отмененные",
        "cancel"
      ]
    },
    "deleted_orders": {
      "title_ru": "Удалённые заказы",
      "sql": "COUNT(DISTINCT order_id) FILTER (WHERE status_order = 'delete')",
      "terms": [
        "удаленные",
        "удалено",
        "delete"
      ]
    },
    "declined_tenders": {
      "title_ru": "Отклонения тендеров",
      "sql": "COUNT(*) FILTER (WHERE status_tender = 'decline')",
      "terms": [
        "отклонения",
        "отклонено",
        "decline",
        "отказы"
      ]
    },
    "revenue": {
      "title_ru": "Оборот/выручка по завершённым заказам",
      "sql": "SUM(price_order_local) FILTER (WHERE status_order = 'done')",
      "terms": [
        "выручка",
        "оборот",
        "сумма заказов"
      ]
    },
    "avg_order_price": {
      "title_ru": "Средний чек",
      "sql": "AVG(price_order_local) FILTER (WHERE status_order = 'done')",
      "terms": [
        "средний чек",
        "средняя цена",
        "avg price"
      ]
    },
    "max_order_price": {
      "title_ru": "Максимальная стоимость заказа",
      "sql": "MAX(price_order_local)",
      "terms": [
        "максимальная цена",
        "самый дорогой",
        "дорогие заказы"
      ]
    },
    "avg_distance_km": {
      "title_ru": "Среднее расстояние поездки в км",
      "sql": "AVG(distance_in_meters) / 1000.0",
      "terms": [
        "среднее расстояние",
        "дистанция",
        "километры"
      ]
    },
    "avg_duration_minutes": {
      "title_ru": "Средняя длительность поездки в минутах",
      "sql": "AVG(duration_in_seconds) / 60.0",
      "terms": [
        "средняя длительность",
        "время поездки",
        "минуты"
      ]
    },
    "driver_orders": {
      "title_ru": "Заказы по водителям",
      "sql": "COUNT(DISTINCT order_id) WHERE driver_id IS NOT NULL",
      "terms": [
        "топ водителей",
        "водители по заказам",
        "рейтинг водителей",
        "сколько заказов у водителей"
      ]
    },
    "driver_done_orders": {
      "title_ru": "Выполненные заказы по водителям",
      "sql": "COUNT(DISTINCT order_id) WHERE driver_id IS NOT NULL AND status_order = 'done'",
      "terms": [
        "водители по выполненным заказам",
        "кто из водителей выполнил больше всего заказов",
        "выполненные заказы водителей"
      ]
    }
  },
  "synonyms": {
    "заказы": "COUNT(DISTINCT order_id)",
    "поездки": "order_id / status_order",
    "выполненные": "status_order = 'done'",
    "завершенные": "status_order = 'done'",
    "отмены": "status_order = 'cancel'",
    "отмененные": "status_order = 'cancel'",
    "удаленные": "status_order = 'delete'",
    "отклонения": "status_tender = 'decline'",
    "отказы": "status_tender = 'decline'",
    "выручка": "SUM(price_order_local) WHERE status_order = 'done'",
    "оборот": "SUM(price_order_local) WHERE status_order = 'done'",
    "средний чек": "AVG(price_order_local) WHERE status_order = 'done'",
    "цена": "price_order_local",
    "стоимость": "price_order_local",
    "город": "city_id",
    "водитель": "driver_id",
    "пользователь": "user_id",
    "дата": "order_timestamp",
    "длительность": "duration_in_seconds",
    "расстояние": "distance_in_meters",
    "топ водителей": "driver_id IS NOT NULL; GROUP BY driver_id; ORDER BY COUNT(DISTINCT order_id) DESC",
    "лучшие водители": "driver_id IS NOT NULL; GROUP BY driver_id; ORDER BY COUNT(DISTINCT order_id) DESC",
    "водители по заказам": "driver_id IS NOT NULL; GROUP BY driver_id; COUNT(DISTINCT order_id)",
    "рейтинг водителей": "driver_id IS NOT NULL; GROUP BY driver_id; COUNT(DISTINCT order_id)"
  },
  "sql_rules_ru": [
    "Для бизнес-подсчёта заказов используй COUNT(DISTINCT order_id).",
    "Для списка заказов выбирай order_id, tender_id, city_id, status_order, order_timestamp и нужную метрику.",
    "Для периода используй order_timestamp и полуинтервалы >= start AND < end.",
    "Для 'выручки' и 'среднего чека' обычно фильтруй status_order = 'done'.",
    "Не используй id: такой колонки нет. Есть order_id и tender_id.",
    "Не используй SELECT *. Выбирай только нужные колонки.",
    "Если пользователь просит рейтинг, топ или список водителей по заказам, обязательно добавляй WHERE driver_id IS NOT NULL; NULL driver_id означает отсутствие назначенного водителя и не должен попадать в топ водителей.",
    "Если пользователь явно спрашивает выполненные заказы водителей, добавляй WHERE driver_id IS NOT NULL AND status_order = 'done'."
  ]
}